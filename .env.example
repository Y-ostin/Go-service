# ─────────────────────────────────────────────────────────────────────────────
# go-binlog-service — Variables de entorno
# Copiar a .env y ajustar valores para tu entorno.
# NUNCA commitear .env con credenciales reales.
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor HTTP ─────────────────────────────────────────────────────────────
SERVER_PORT=8090
SERVER_MAX_CLIENTS=500

# ── MariaDB Replication ────────────────────────────────────────────────────────
# Host del servidor MariaDB (no el DB_HOST del backend principal — puede ser el mismo)
DB_HOST=127.0.0.1
DB_PORT=3306

# Usuario con PRIVILEGIO REPLICATION SLAVE únicamente
DB_REPL_USER=replicator
DB_REPL_PASSWORD=cambiar_en_produccion

# CRÍTICO: server-id ÚNICO en todo el cluster de replicación.
# - El MariaDB primario usa server-id=1
# - Este servicio Go debe usar un número diferente, ej: 100
# - Si tienes múltiples instancias del Go service, cada una necesita un server-id distinto
DB_SERVER_ID=100

# ── Binlog ────────────────────────────────────────────────────────────────────
# "mariadb" para MariaDB, "mysql" para MySQL
BINLOG_FLAVOR=mariadb

# Usar GTID en lugar de File+Position (más robusto en ambientes con failover)
# Requiere que MariaDB tenga GTID habilitado: gtid_mode=ON
BINLOG_USE_GTID=false

# Schemas a monitorear (separados por coma). Vacío = todos.
# Ejemplo: ccip_erp_legacy,ccip_reports
BINLOG_SCHEMAS=ccip_erp_legacy

# Tablas específicas a monitorear en formato schema.tabla (separadas por coma).
# Vacío = todas las tablas de BINLOG_SCHEMAS.
# Ejemplo: ccip_erp_legacy.financial_results,ccip_erp_legacy.invoices
BINLOG_TABLES=

# ── Persistencia de posición ──────────────────────────────────────────────────
# "file" = archivo JSON en disco | "redis" = Redis (para multi-instancia)
POSITION_STORAGE=file
POSITION_FILE_PATH=/data/binlog_position.json

# ── Throttling ────────────────────────────────────────────────────────────────
# Máximo de eventos por segundo antes de activar el batcher
THROTTLE_MAX_EPS=100
# Máximo de eventos por batch
THROTTLE_BATCH_SIZE=50
# Número de goroutines en el worker pool
THROTTLE_WORKERS=4

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
# json (producción) | console (desarrollo)
LOG_FORMAT=json
