[mysqld]
# ─────────────────────────────────────────────────────────────────────────────
# Configuración crítica del Binary Log para MariaDB 10.4
# ─────────────────────────────────────────────────────────────────────────────

# Identificador único del servidor en el cluster de replicación.
# DEBE ser diferente al server-id del Go service (que usará 100).
server-id = 1

# Habilitar el binary log — requerido para replicación.
log-bin = mysql-bin

# OBLIGATORIO para nuestro caso de uso:
# ROW = registra los valores exactos de cada fila antes y después del cambio.
# STATEMENT = registra la query SQL (no sirve para nuestro caso).
# MIXED = mezcla automática (no confiable para detección de cambios).
binlog_format = ROW

# Nivel de detalle del ROW format:
# FULL = registra TODAS las columnas en before/after (más seguro para replicación)
# MINIMAL = solo columnas modificadas (menos datos pero menos info para nosotros)
binlog_row_image = FULL

# Retención del binlog en días. Ajustar según espacio en disco.
# En producción con alto volumen de transacciones, considerar 1-3 días.
expire_logs_days = 7

# Tamaño máximo de cada archivo binlog antes de rotar (1GB).
max_binlog_size = 1073741824

# Sincronizar el binlog a disco en cada transacción.
# 1 = máxima durabilidad (ACID compliant), puede tener impacto en performance.
# 0 = el OS decide cuándo flushear (más rápido pero puede perder datos en crash).
sync_binlog = 1

# Habilitar tabla de posición del esclavo en InnoDB (más seguro que archivo).
# No aplica directamente aquí pero es buena práctica.
relay_log_recovery = 1

# Deshabilitar binlog para transacciones de replicación entrantes
# (evita loops en topologías maestro-maestro).
log_slave_updates = ON
